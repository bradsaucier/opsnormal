{
  "name": "opsnormal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Offline-first personal readiness tracker for daily balance across work, home, relationships, body, and rest.",
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview": "vite preview",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build:e2e",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "dexie": "^4.4.1",
    "dexie-react-hooks": "^1.1.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "^6.0.0",
    "globals": "^16.0.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.26.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
